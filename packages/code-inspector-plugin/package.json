{
  "name": "code-inspector-plugin",
  "version": "1.4.5",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "typings": "./types/index.d.ts",
  "repository": "git@github.com:zh-lx/code-inspector.git",
  "author": "zh-lx <18366276315@163.com>",
  "license": "MIT",
  "scripts": {
    "clear": "rimraf ./dist && rimraf ./types",
    "sync:runtime-deps": "node ./scripts/sync-runtime-deps.mjs",
    "build": "pnpm sync:runtime-deps && pnpm clear && tsc && vite build && node ./scripts/copy-core-client-bundles.mjs",
    "pub": "pnpm publish",
    "pub:beta": "pnpm publish --tag beta"
  },
  "files": [
    "dist",
    "types",
    "skills"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dist/*": {
      "import": {
        "default": "./dist/*"
      },
      "require": {
        "default": "./dist/*"
      }
    }
  },
  "homepage": "https://inspector.fe-dev.cn/en",
  "description": "Click the dom on the page, it will open your IDE and position the cursor to the source code location of the dom.",
  "keywords": [
    "webpack",
    "vite",
    "plugin",
    "vue",
    "vscode",
    "inspector",
    "inspect"
  ],
  "bugs": {
    "url": "https://github.com/zh-lx/code-inspector/issues"
  },
  "dependencies": {
    "@code-inspector/core": "workspace:*",
    "@code-inspector/esbuild": "workspace:*",
    "@code-inspector/mako": "workspace:*",
    "@code-inspector/turbopack": "workspace:*",
    "@code-inspector/vite": "workspace:*",
    "@code-inspector/webpack": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "@mcpc-tech/acp-ai-provider": "^0.1.50",
    "@vue/compiler-dom": "^3.5.13",
    "ai": "^5.0.117",
    "chalk": "4.1.1",
    "dotenv": "^16.1.4",
    "launch-ide": "1.4.3",
    "portfinder": "^1.0.28"
  },
  "devDependencies": {
    "@types/node": "^16.0.1",
    "typescript": "^4.9.3",
    "vite": "^4.1.0"
  }
}
